<?php
/**
 * Layout — nagłówek. Oczekuje tablicy $meta (z Controller::view()).
 * @var array $meta
 */
$navItems = [
	'/'          => 'Główna',
	'/o-mnie'    => 'O mnie',
	'/portfolio' => 'Portfolio',
	'/faq'       => 'FAQ',
	'/kontakt'   => 'Kontakt',
];
$currentPath = rtrim(parse_url($_SERVER['REQUEST_URI'] ?? '/', PHP_URL_PATH), '/') ?: '/';
?>
<!doctype html>
<html lang="<?= htmlspecialchars(SITE['lang']) ?>">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title><?= htmlspecialchars($meta['title']) ?></title>

	<?php Seo::meta($meta); ?>

	<!-- Bootstrap 5.3.8 -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet">
	<link href="/assets/bootstrap_custom.css" rel="stylesheet">
	<link href="/assets/index.css" rel="stylesheet">

	<?php Seo::jsonLd($meta); ?>
</head>
<body>
<nav id="mainNavbar" class="navbar navbar-expand-lg sticky-top navbar-eznawca border-bottom">
	<div class="container">
		<a class="navbar-brand d-flex align-items-center" href="/" aria-label="Andrzej Mazur EZNAWCA — strona główna">
			<img src="/img/eznawca-logo.svg" alt="Andrzej Mazur EZNAWCA" height="26">
		</a>
		<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Menu">
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="collapse navbar-collapse" id="mainNav">
			<ul class="navbar-nav ms-auto">
				<?php foreach ($navItems as $url => $label):
					$active = ($currentPath === $url) || ($url !== '/' && strpos($currentPath, $url) === 0); ?>
				<li class="nav-item">
					<a class="nav-link<?= $active ? ' active' : '' ?>"<?= $active ? ' aria-current="page"' : '' ?> href="<?= $url ?>"><?= $label ?></a>
				</li>
				<?php endforeach; ?>
			</ul>
		</div>
	</div>
</nav>

<main class="container py-4">
	<?php if (!empty($meta['breadcrumb'])): ?>
	<nav aria-label="breadcrumb">
		<ol class="breadcrumb">
			<?php $last = count($meta['breadcrumb']) - 1;
			foreach ($meta['breadcrumb'] as $i => $crumb): ?>
				<?php if ($i === $last): ?>
				<li class="breadcrumb-item active" aria-current="page"><?= htmlspecialchars($crumb['label']) ?></li>
				<?php else: ?>
				<li class="breadcrumb-item"><a href="<?= htmlspecialchars($crumb['url']) ?>"><?= htmlspecialchars($crumb['label']) ?></a></li>
				<?php endif; ?>
			<?php endforeach; ?>
		</ol>
	</nav>
	<?php endif; ?>
