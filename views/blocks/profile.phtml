		<picture>
			<?php if (!empty($image['webp'])): ?>
			<source srcset="<?= htmlspecialchars($image['webp'], ENT_QUOTES, 'UTF-8') ?>" type="image/webp">
			<?php endif; ?>
			<img class="img-fluid rounded shadow-sm border mb-3" src="<?= htmlspecialchars((string)($image['jpg'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" alt="<?= htmlspecialchars((string)($image['alt'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" title="<?= htmlspecialchars((string)($image['title'] ?? ''), ENT_QUOTES, 'UTF-8') ?>" width="<?= (int)($image['width'] ?? 0) ?>" height="<?= (int)($image['height'] ?? 0) ?>">
		</picture>
	</div>
	<div class="col-lg-8">
		<?php if (!empty($block['title'])): ?>
		<h1 class="mb-3"><?= htmlspecialchars((string)$block['title'], ENT_QUOTES, 'UTF-8') ?></h1>
		<?php endif; ?>
