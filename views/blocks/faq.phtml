<?php
/** @var array $block */
$accordionId = 'faqAccordion-' . preg_replace('/[^a-z0-9_-]/i', '', (string)($block['id'] ?? 'main'));
?>
<section>
	<?php if (!empty($block['title'])): ?>
	<h1 class="mb-4"><?= htmlspecialchars((string)$block['title'], ENT_QUOTES, 'UTF-8') ?></h1>
	<?php endif; ?>

	<?php if (empty($block['items'])): ?>
	<p class="text-secondary">Pytania i odpowiedzi zostaną dodane w kolejnym etapie.</p>
	<?php else: ?>
	<div class="accordion accordion-flush" id="<?= htmlspecialchars($accordionId, ENT_QUOTES, 'UTF-8') ?>">
		<?php foreach ((array)$block['items'] as $i => $item):
			$collapseId = $accordionId . '-' . $i; ?>
		<div class="accordion-item">
			<h2 class="accordion-header">
				<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#<?= htmlspecialchars($collapseId, ENT_QUOTES, 'UTF-8') ?>">
					<?= htmlspecialchars((string)($item['title'] ?? ''), ENT_QUOTES, 'UTF-8') ?>
				</button>
			</h2>
			<div id="<?= htmlspecialchars($collapseId, ENT_QUOTES, 'UTF-8') ?>" class="accordion-collapse collapse" data-bs-parent="#<?= htmlspecialchars($accordionId, ENT_QUOTES, 'UTF-8') ?>">
				<div class="accordion-body"><?= htmlspecialchars((string)($item['text'] ?? ''), ENT_QUOTES, 'UTF-8') ?></div>
			</div>
		</div>
		<?php endforeach; ?>
	</div>
	<?php endif; ?>
</section>
